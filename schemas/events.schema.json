{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TraceBench Event",
  "type": "object",
  "required": ["schema_version", "event_id", "project_id", "sequence", "created_at", "actor", "event_type", "status", "payload"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "event_id": { "type": "string", "pattern": "^evt_[0-9]{6}$" },
    "project_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "actor": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "enum": ["user", "system", "ai", "import"] },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "event_type": {
      "enum": [
        "project_created",
        "project_metadata_updated",
        "initial_intake_updated",
        "photo_added",
        "photo_reference_points_set",
        "photo_layer_aligned",
        "damage_region_marked",
        "suspect_region_marked",
        "component_created",
        "component_updated",
        "component_marked_unknown",
        "footprint_marked_not_populated",
        "pin_defined",
        "visual_trace_added",
        "component_visual_placement_confirmed",
        "measurement_recorded",
        "net_connection_confirmed",
        "repair_action_recorded",
        "claim_invalidated",
        "conflict_detected",
        "conflict_resolved",
        "export_created"
      ]
    },
    "status": { "enum": ["draft", "pending_review", "accepted", "rejected", "superseded", "reverted"] },
    "payload": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "event_type": { "const": "measurement_recorded" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/measurement_recorded" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "repair_action_recorded" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/repair_action_recorded" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "photo_added" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/photo_added" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "damage_region_marked" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/damage_region_marked" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "suspect_region_marked" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/suspect_region_marked" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "visual_trace_added" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/visual_trace_added" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "component_visual_placement_confirmed" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/component_visual_placement_confirmed" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "conflict_detected" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/conflict_detected" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "conflict_resolved" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/conflict_resolved" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "footprint_marked_not_populated" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/footprint_marked_not_populated" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "component_created" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/component_created" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "pin_defined" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/pin_defined" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "net_connection_confirmed" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/net_connection_confirmed" } } }
    },
    {
      "if": { "properties": { "event_type": { "const": "claim_invalidated" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/claim_invalidated" } } }
    }
  ],
  "$defs": {
    "measurement_recorded": {
      "type": "object",
      "required": ["measurement_id", "mode", "from", "to", "reading", "power_state"],
      "properties": {
        "measurement_id": { "type": "string", "pattern": "^M[0-9]+$" },
        "mode": { "enum": ["continuity", "resistance", "voltage_dc", "voltage_ac", "diode", "capacitance", "frequency"] },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "reading": {
          "type": "object",
          "required": ["kind", "value", "unit"],
          "properties": {
            "kind": { "enum": ["numeric", "boolean", "categorical", "over_range"] },
            "value": { "type": ["number", "boolean", "string", "null"] },
            "unit": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "power_state": { "enum": ["off", "on", "unknown"] }
      },
      "additionalProperties": true
    },
    "repair_action_recorded": {
      "type": "object",
      "required": ["repair_action_id", "action_type", "targets", "reason", "invalidation_policy"],
      "properties": {
        "repair_action_id": { "type": "string", "minLength": 1 },
        "action_type": {
          "enum": [
            "replace_component",
            "remove_component",
            "rework_solder",
            "clean_board",
            "bypass_trace",
            "cut_trace",
            "other"
          ]
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["target_type", "target_id"],
            "properties": {
              "target_type": {
                "enum": ["component", "pin", "pad", "footprint", "net", "trace", "via", "connector", "area"]
              },
              "target_id": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        },
        "reason": { "type": "string" },
        "invalidation_policy": {
          "type": "object",
          "required": ["direct_component_measurements", "connected_net_measurements"],
          "properties": {
            "direct_component_measurements": { "enum": ["stale_after_repair", "no_change"] },
            "connected_net_measurements": { "const": "no_change" }
          },
          "additionalProperties": true
        },
        "after": { "type": "object", "additionalProperties": true },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "conflict_detected": {
      "type": "object",
      "required": ["conflict_id", "conflict_type", "between", "detected_at_sequence"],
      "properties": {
        "conflict_id": { "type": "string", "pattern": "^CONF[0-9]+$" },
        "conflict_type": { "enum": ["measurement_contradiction", "net_topology_conflict", "evidence_quality_conflict", "component_identity_conflict", "population_status_conflict"] },
        "between": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "detected_at_sequence": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" },
        "auto_detected": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "conflict_resolved": {
      "type": "object",
      "required": ["conflict_id", "resolution_type", "resolved_by"],
      "properties": {
        "conflict_id": { "type": "string", "minLength": 1 },
        "resolution_type": {
          "enum": ["accepted_events", "invalidated_events", "superseded_by_repair", "not_a_conflict"]
        },
        "resolved_by": { "type": "object", "required": ["type", "id"], "additionalProperties": true },
        "accepted_event_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "invalidated_event_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "claim_invalidated_event_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "footprint_marked_not_populated": {
      "type": "object",
      "required": ["footprint_id", "population_status", "allowed_in_fault_hypotheses"],
      "properties": {
        "footprint_id": { "type": "string", "minLength": 1 },
        "designator": { "type": ["string", "null"] },
        "population_status": { "const": "not_populated" },
        "allowed_in_fault_hypotheses": { "const": false },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "component_created": {
      "type": "object",
      "required": ["component_id"],
      "properties": {
        "component_id": { "type": "string", "minLength": 1 },
        "designator": { "type": ["string", "null"] },
        "type": { "type": ["string", "null"] },
        "package": { "type": ["string", "null"] },
        "pin_count": { "type": ["integer", "null"], "minimum": 0 },
        "marking": { "type": ["string", "null"] },
        "status": { "enum": ["needs_identification", "identified", "confirmed", "suspect", "verified_good"] },
        "mpn": { "type": ["string", "null"] },
        "datasheet_url": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "pin_defined": {
      "type": "object",
      "required": ["component_id", "pin_id"],
      "properties": {
        "component_id": { "type": "string", "minLength": 1 },
        "pin_id": { "type": "string", "minLength": 1 },
        "label": { "type": ["string", "null"] },
        "status": { "enum": ["unknown", "user_confirmed_visual", "source_imported_unverified", "datasheet_confirmed"] },
        "physical_number": { "type": ["integer", "null"] }
      },
      "additionalProperties": true
    },
    "photo_added": {
      "type": "object",
      "required": ["photo_id", "mode", "path"],
      "properties": {
        "photo_id": { "type": "string", "pattern": "^photo_[a-z0-9_]+$" },
        "mode": { "enum": ["normal", "backlight", "macro", "side_light"] },
        "path": { "type": "string", "pattern": "^photos/.*\\.(jpg|jpeg|png|webp)$" },
        "notes": { "type": "string" },
        "sha256": { "type": ["string", "null"] },
        "source_device": { "type": "string" },
        "exif_stripped": { "type": ["boolean", "null"] },
        "layer": { "enum": ["top", "bottom", "side", "detail", null] }
      },
      "additionalProperties": true
    },
    "damage_region_marked": {
      "type": "object",
      "required": ["region_id", "photo_id", "bbox", "damage_type"],
      "properties": {
        "region_id": { "type": "string", "pattern": "^DMG[0-9]+$" },
        "photo_id": { "type": "string", "minLength": 1 },
        "bbox": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": true
        },
        "damage_type": {
          "enum": [
            "burn",
            "corrosion",
            "physical_break",
            "solder_bridge",
            "missing_component",
            "lifted_pad",
            "unknown"
          ]
        },
        "notes": { "type": "string" },
        "severity": { "enum": ["minor", "moderate", "severe"] },
        "affects_components": { "type": ["array", "null"] }
      },
      "additionalProperties": true
    },
    "suspect_region_marked": {
      "type": "object",
      "required": ["region_id", "photo_id", "bbox", "reason"],
      "properties": {
        "region_id": { "type": "string", "pattern": "^SUSP[0-9]+$" },
        "photo_id": { "type": "string", "minLength": 1 },
        "bbox": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": true
        },
        "reason": { "type": "string" },
        "notes": { "type": "string" },
        "affects_components": { "type": ["array", "null"] },
        "priority": { "enum": ["low", "medium", "high"] }
      },
      "additionalProperties": true
    },
    "visual_trace_added": {
      "type": "object",
      "required": ["trace_id", "photo_id", "from_point", "to_point", "evidence_type"],
      "properties": {
        "trace_id": { "type": "string", "pattern": "^VT[0-9]+$" },
        "photo_id": { "type": "string", "minLength": 1 },
        "from_point": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": true
        },
        "to_point": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": true
        },
        "from_component": { "type": ["string", "null"] },
        "to_component": { "type": ["string", "null"] },
        "from_pin": { "type": ["string", "null"] },
        "to_pin": { "type": ["string", "null"] },
        "evidence_type": { "const": "visual_trace" },
        "confidence": { "enum": ["low", "medium", "high"] },
        "layer": { "enum": ["top", "bottom", "inner_unknown"] },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "component_visual_placement_confirmed": {
      "type": "object",
      "required": [
        "component_id",
        "coordinate_space",
        "board_side",
        "center_x",
        "center_y",
        "rotation_deg"
      ],
      "properties": {
        "component_id": { "type": "string", "minLength": 1 },
        "coordinate_space": { "enum": ["board_normalized", "photo_local"] },
        "board_side": { "enum": ["top", "bottom", "unknown"] },
        "center_x": { "type": "number" },
        "center_y": { "type": "number" },
        "rotation_deg": { "type": "number", "minimum": -180, "exclusiveMaximum": 180 },
        "scale": { "type": "number", "exclusiveMinimum": 0 },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "template_id": { "type": "string", "minLength": 1 },
        "source_photo_id": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "required": ["scale"],
              "not": {
                "anyOf": [
                  { "required": ["width"] },
                  { "required": ["height"] }
                ]
              }
            },
            {
              "required": ["width", "height"],
              "not": { "required": ["scale"] }
            }
          ]
        },
        {
          "if": {
            "properties": { "coordinate_space": { "const": "photo_local" } },
            "required": ["coordinate_space"]
          },
          "then": {
            "required": ["source_photo_id"],
            "properties": {
              "center_x": { "type": "number", "minimum": 0 },
              "center_y": { "type": "number", "minimum": 0 },
              "width": { "type": "number", "exclusiveMinimum": 0 },
              "height": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          "else": {
            "not": { "required": ["source_photo_id"] },
            "properties": {
              "center_x": { "type": "number", "minimum": 0, "maximum": 1 },
              "center_y": { "type": "number", "minimum": 0, "maximum": 1 },
              "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
              "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "net_connection_confirmed": {
      "type": "object",
      "required": ["net_id", "from", "to", "confirmation_basis", "confirmed_by_event_ids"],
      "properties": {
        "net_id": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "confirmation_basis": { "const": "measured" },
        "confirmed_by_event_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "label": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "claim_invalidated": {
      "type": "object",
      "required": ["invalidates_event_id", "reason", "invalidation_type"],
      "properties": {
        "invalidates_event_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "invalidation_type": {
          "enum": ["superseded", "retracted", "stale_after_repair", "conflict_resolution", "user_correction"]
        },
        "superseded_by_event_id": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
