{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TraceBench Known Facts",
  "type": "object",
  "required": ["project_id", "components", "pins", "measurements", "nets", "excluded_from_fault_candidates"],
  "properties": {
    "project_id": { "type": "string" },
    "components": { "type": "array" },
    "pins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component_id", "pin_id"],
        "properties": {
          "component_id": { "type": "string", "minLength": 1 },
          "pin_id": { "type": "string", "minLength": 1 },
          "label": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "physical_number": { "type": ["integer", "null"] }
        },
        "additionalProperties": true
      }
    },
    "component_pin_index": {
      "type": "object",
      "description": "Maps component_id to list of pin_ids. Derived from pin_defined events.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["photo_id", "mode", "path"],
        "properties": {
          "photo_id": { "type": "string", "pattern": "^photo_[a-z0-9_]+$" },
          "mode": { "enum": ["normal", "backlight", "macro", "side_light"] },
          "path": { "type": "string", "pattern": "^photos/.*\\.(jpg|jpeg|png|webp)$" },
          "notes": { "type": "string" },
          "sha256": { "type": ["string", "null"] },
          "source_device": { "type": "string" },
          "exif_stripped": { "type": ["boolean", "null"] },
          "layer": { "enum": ["top", "bottom", "side", "detail", null] }
        },
        "additionalProperties": true
      }
    },
    "damage_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["region_id", "photo_id", "bbox", "damage_type"],
        "properties": {
          "region_id": { "type": "string", "pattern": "^DMG[0-9]+$" },
          "photo_id": { "type": "string", "minLength": 1 },
          "bbox": {
            "type": "object",
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number", "exclusiveMinimum": 0 },
              "height": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": true
          },
          "damage_type": {
            "enum": [
              "burn",
              "corrosion",
              "physical_break",
              "solder_bridge",
              "missing_component",
              "lifted_pad",
              "unknown"
            ]
          },
          "notes": { "type": "string" },
          "severity": { "enum": ["minor", "moderate", "severe"] },
          "affects_components": { "type": ["array", "null"] }
        },
        "additionalProperties": true
      }
    },
    "suspect_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["region_id", "photo_id", "bbox", "reason"],
        "properties": {
          "region_id": { "type": "string", "pattern": "^SUSP[0-9]+$" },
          "photo_id": { "type": "string", "minLength": 1 },
          "bbox": {
            "type": "object",
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number", "exclusiveMinimum": 0 },
              "height": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": true
          },
          "reason": { "type": "string" },
          "notes": { "type": "string" },
          "affects_components": { "type": ["array", "null"] },
          "priority": { "enum": ["low", "medium", "high"] }
        },
        "additionalProperties": true
      }
    },
    "visual_traces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trace_id", "photo_id", "from_point", "to_point", "evidence_type"],
        "properties": {
          "trace_id": { "type": "string", "pattern": "^VT[0-9]+$" },
          "photo_id": { "type": "string", "minLength": 1 },
          "from_point": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "additionalProperties": true
          },
          "to_point": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "additionalProperties": true
          },
          "evidence_type": { "const": "visual_trace" },
          "from_component": { "type": ["string", "null"] },
          "to_component": { "type": ["string", "null"] },
          "from_pin": { "type": ["string", "null"] },
          "to_pin": { "type": ["string", "null"] },
          "confidence": { "enum": ["low", "medium", "high"] },
          "layer": { "enum": ["top", "bottom", "inner_unknown"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "component_visual_placements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "component_id",
          "coordinate_space",
          "board_side",
          "center_x",
          "center_y",
          "rotation_deg",
          "source_event_id",
          "status"
        ],
        "properties": {
          "component_id": { "type": "string", "minLength": 1 },
          "coordinate_space": { "enum": ["board_normalized", "photo_local"] },
          "board_side": { "enum": ["top", "bottom", "unknown"] },
          "center_x": { "type": "number" },
          "center_y": { "type": "number" },
          "rotation_deg": { "type": "number", "minimum": -180, "exclusiveMaximum": 180 },
          "scale": { "type": "number", "exclusiveMinimum": 0 },
          "width": { "type": "number", "exclusiveMinimum": 0 },
          "height": { "type": "number", "exclusiveMinimum": 0 },
          "source_photo_id": { "type": "string", "minLength": 1 },
          "template_id": { "type": "string", "minLength": 1 },
          "source_event_id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["user_confirmed_visual"] }
        },
        "allOf": [
          {
            "oneOf": [
              {
                "required": ["scale"],
                "not": {
                  "anyOf": [
                    { "required": ["width"] },
                    { "required": ["height"] }
                  ]
                }
              },
              {
                "required": ["width", "height"],
                "not": { "required": ["scale"] }
              }
            ]
          },
          {
            "if": {
              "properties": { "coordinate_space": { "const": "photo_local" } },
              "required": ["coordinate_space"]
            },
            "then": {
              "required": ["source_photo_id"],
              "properties": {
                "center_x": { "type": "number", "minimum": 0 },
                "center_y": { "type": "number", "minimum": 0 },
                "width": { "type": "number", "exclusiveMinimum": 0 },
                "height": { "type": "number", "exclusiveMinimum": 0 }
              }
            },
            "else": {
              "not": { "required": ["source_photo_id"] },
              "properties": {
                "center_x": { "type": "number", "minimum": 0, "maximum": 1 },
                "center_y": { "type": "number", "minimum": 0, "maximum": 1 },
                "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
                "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "photo_to_board_alignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "alignment_id",
          "source_photo_id",
          "board_side",
          "coordinate_space_from",
          "coordinate_space_to",
          "reference_points_photo",
          "reference_points_board",
          "transform_type",
          "alignment_quality_label",
          "source_event_id",
          "status"
        ],
        "properties": {
          "alignment_id": { "type": "string", "pattern": "^ALN[0-9]+$" },
          "source_photo_id": { "type": "string", "pattern": "^photo_[a-z0-9_]+$" },
          "board_side": { "enum": ["top", "bottom", "unknown"] },
          "coordinate_space_from": { "const": "photo_local" },
          "coordinate_space_to": { "const": "board_normalized" },
          "reference_points_photo": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number", "minimum": 0 },
                "y": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "reference_points_board": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number", "minimum": 0, "maximum": 1 },
                "y": { "type": "number", "minimum": 0, "maximum": 1 }
              },
              "additionalProperties": false
            }
          },
          "transform_type": { "enum": ["similarity", "affine"] },
          "alignment_quality_label": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" },
          "source_event_id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["user_confirmed_alignment"] }
        },
        "additionalProperties": false
      }
    },
    "board_outline": {
      "type": "object",
      "required": ["coordinate_space", "outer_polygon", "source_event_id"],
      "properties": {
        "coordinate_space": { "const": "board_normalized" },
        "outer_polygon": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number", "minimum": 0, "maximum": 1 },
              "y": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "physical_width_mm": { "type": "number", "exclusiveMinimum": 0 },
        "physical_height_mm": { "type": "number", "exclusiveMinimum": 0 },
        "source_event_id": { "type": "string", "minLength": 1 }
      },
      "dependentRequired": {
        "physical_width_mm": ["physical_height_mm"],
        "physical_height_mm": ["physical_width_mm"]
      },
      "additionalProperties": false
    },
    "board_outline_conflicts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["conflict_type", "source_event_ids", "candidates"],
        "properties": {
          "conflict_type": { "const": "board_outline_divergence" },
          "source_event_ids": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "candidates": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["coordinate_space", "outer_polygon", "source_event_id"],
              "properties": {
                "coordinate_space": { "const": "board_normalized" },
                "outer_polygon": {
                  "type": "array",
                  "minItems": 3,
                  "items": {
                    "type": "object",
                    "required": ["x", "y"],
                    "properties": {
                      "x": { "type": "number", "minimum": 0, "maximum": 1 },
                      "y": { "type": "number", "minimum": 0, "maximum": 1 }
                    },
                    "additionalProperties": false
                  }
                },
                "physical_width_mm": { "type": "number", "exclusiveMinimum": 0 },
                "physical_height_mm": { "type": "number", "exclusiveMinimum": 0 },
                "source_event_id": { "type": "string", "minLength": 1 }
              },
              "dependentRequired": {
                "physical_width_mm": ["physical_height_mm"],
                "physical_height_mm": ["physical_width_mm"]
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "measurements": { "type": "array" },
    "nets": { "type": "array" },
    "excluded_from_fault_candidates": { "type": "array" }
  },
  "allOf": [
    {
      "not": {
        "required": ["board_outline", "board_outline_conflicts"]
      }
    }
  ],
  "additionalProperties": true
}
